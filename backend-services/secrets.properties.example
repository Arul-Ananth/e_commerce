# Copy this file to backend-services/secrets.properties and fill real values.
# This file is gitignored and loaded at runtime via:
# spring.config.import=optional:file:./secrets.properties

# Required for JWT signing
APP_JWT_SECRET=replace-with-a-random-secret-at-least-32-chars

# DB password if not provided via env var
SPRING_DATASOURCE_PASSWORD=admin

# Stripe (required for checkout session creation + webhook verification)
APP_STRIPE_SECRET_KEY=sk_test_replace_me
APP_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
APP_STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Payment gateway selector: stripe | razorpay
APP_PAYMENT_GATEWAY=stripe
APP_PAYMENT_DEFAULT_CURRENCY=usd

# Razorpay (required only when APP_PAYMENT_GATEWAY=razorpay)
APP_RAZORPAY_KEY_ID=rzp_test_replace_me
APP_RAZORPAY_KEY_SECRET=replace_me
APP_RAZORPAY_WEBHOOK_SECRET=replace_me
